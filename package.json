{
  "name": "starknet-wallet-migrator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Migrate ERC-20 tokens and NFTs from one Starknet wallet to another in a single signed multicall.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "starknet": "8.9.2",
    "starknetkit": "3.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
